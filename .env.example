# ═══════════════════════════════════════════════════════════════
# Observability Stack — Environment Variables
# ───────────────────────────────────────────────────────────────
# Local use: copy this file to .env
#   cp .env.example .env
#
# Coolify deployment: set these in the Coolify UI under
# Environment Variables for this service. Coolify auto-detects
# all ${VAR} references from the compose file and shows them
# as editable fields.
# ═══════════════════════════════════════════════════════════════

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password

# Set to the domain you assign in Coolify (e.g. https://grafana.yourdomain.com)
GRAFANA_ROOT_URL=https://grafana.yourdomain.com

# ── GlitchTip ────────────────────────────────────────────────
# Generate a secure key:
#   python3 -c "import secrets; print(secrets.token_hex(50))"
GLITCHTIP_SECRET_KEY=changeme_replace_with_output_of_python_command_above

# Strong password for GlitchTip's PostgreSQL database
GLITCHTIP_DB_PASSWORD=changeme_db_password

# Must match the domain you assign in Coolify (include https://)
GLITCHTIP_DOMAIN=https://errors.yourdomain.com

# ── GlitchTip Email (optional) ───────────────────────────────
# Defaults to printing emails to container logs (good for testing).
# For production email delivery, switch the backend and fill in SMTP details.
GLITCHTIP_FROM_EMAIL=noreply@yourdomain.com
GLITCHTIP_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Uncomment and fill in for SMTP:
# GLITCHTIP_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# GLITCHTIP_EMAIL_HOST=smtp.yourdomain.com
# GLITCHTIP_EMAIL_PORT=587
# GLITCHTIP_EMAIL_HOST_USER=your@email.com
# GLITCHTIP_EMAIL_HOST_PASSWORD=your_smtp_password
# GLITCHTIP_EMAIL_TLS=True

# ── OpenTelemetry Collector ───────────────────────────────────
# These ports are exposed on the HOST for cross-stack access.
# Change only if 4317/4318 are already in use on your server.
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
